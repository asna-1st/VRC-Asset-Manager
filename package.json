{
  "name": "vrc-asset-manager",
  "version": "1.3.0",
  "description": "VRChat Asset Manager Desktop Application",
  "main": "main.js",
  "author": "asna",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "react:dev": "vite",
    "react:build": "vite build",
    "build": "pnpm react:build && electron-builder",
    "build:portable": "pnpm react:build && electron-builder --win portable",
    "build:zip": "pnpm react:build && electron-builder --win zip",
    "build:win": "pnpm react:build && electron-builder --win",
    "build:mac": "pnpm react:build && electron-builder --mac",
    "build:linux": "pnpm react:build && electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "pnpm react:build && electron-builder",
    "release": "pnpm react:build && electron-builder --win zip",
    "bump:patch": "pnpm version patch",
    "bump:minor": "pnpm version minor",
    "bump:major": "pnpm version major",
    "postversion": "git push --follow-tags",
    "publish": "pnpm run publish:patch",
    "publish:patch": "pnpm run bump:patch && pnpm run release",
    "publish:minor": "pnpm run bump:minor && pnpm run release",
    "publish:major": "pnpm run bump:major && pnpm run release"
  },
  "build": {
    "appId": "com.asna.vrcassetmanager",
    "productName": "VRC Asset Manager",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "package.json",
      "dist-react/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "artifactName": "VRC-Asset-Manager-${version}-${os}-${arch}.${ext}",
    "copyright": "Copyright © 2026 asna",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "cross-env": "^7.0.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0"
  }
}
